function stageFor(status: PlanStatus): Stage
{
  if (status.Approved? || status.InProgress?) then
    Stage.ImplementStage
  else
    if status.Complete? then
      Stage.ReviewStage
    else
      Stage.PlanStage
}

lemma stageFor_ensures(status: PlanStatus)
  ensures (!stageFor(status).NoStage?)
  ensures (stageFor(status).ReviewStage? <==> status.Complete?)
