function decideContinue(candidate: Candidate, evidence: Evidence, status: PlanStatus, dryRun: bool): ContinueDecision
{
  if candidate.isAddendum then
    ContinueDecision(Action.Report, Stage.NoStage, SkipReason.AddendumBranch, true)
  else
    if evidence.hasCollectionErrors then
      ContinueDecision(Action.Report, Stage.NoStage, SkipReason.EvidenceCollectionError, true)
    else
      if !(evidence.isClean) then
        ContinueDecision(Action.Report, Stage.NoStage, SkipReason.DirtyWorktree, true)
      else
        if status.Unreadable? then
          ContinueDecision(Action.Report, Stage.NoStage, SkipReason.PlanUnreadable, true)
        else
          if status.Blocked? then
            ContinueDecision(Action.Report, Stage.NoStage, SkipReason.PlanBlocked, true)
          else
            var stage := stageFor(status);
            if (stage.ReviewStage? && !(evidence.hasCommits)) then
              ContinueDecision(Action.Report, Stage.NoStage, SkipReason.NoCommittedWork, true)
            else
              if dryRun then
                ContinueDecision(Action.Report, stage, SkipReason.DryRun, true)
              else
                ContinueDecision(Action.Resume, stage, SkipReason.NoReason, false)
}

