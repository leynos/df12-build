}

function decideReview(candidate: Candidate, evidence: Evidence, assessment: Assessment, mode: Mode, dryRun: bool): ReviewDecision
{
  if ((!mode.Review?) || (!assessment.classification.AdoptComplete?)) then
    ReviewDecision(Action.Report, assessment.classification, SkipReason.NoReason, false)
  else
    var reason := resumeEligibility(candidate, evidence, assessment);
    if (!reason.NoReason?) then
      ReviewDecision(Action.Report, Classification.ContinueManual, reason, true)
    else
      if dryRun then
        ReviewDecision(Action.Report, assessment.classification, SkipReason.DryRun, true)
      else
        ReviewDecision(Action.Resume, assessment.classification, SkipReason.NoReason, false)
}

