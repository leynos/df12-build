datatype Mode = Assess | Review | Continue | OtherMode

datatype Classification = AdoptComplete | ContinueManual | Restart | Abandon | NoClassification

datatype PlanStatus = Draft | Approved | InProgress | Blocked | Complete | Missing | Unreadable | Unknown

datatype Stage = PlanStage | ImplementStage | ReviewStage | NoStage

datatype Action = Report | Resume

datatype SkipReason = AddendumBranch | EvidenceCollectionError | DirtyWorktree | NoCommittedWork | NotTaskScoped | MissingValidationEvidence | MissingExecplan | PlanUnreadable | PlanBlocked | DryRun | NoReason

datatype Candidate = Candidate(isAddendum: bool, hasExecplan: bool)

datatype Evidence = Evidence(hasCollectionErrors: bool, isClean: bool, hasCommits: bool)

datatype Assessment = Assessment(classification: Classification, taskScoped: bool, hasMissingEvidence: bool)

datatype ReviewDecision = ReviewDecision(action: Action, classification: Classification, reason: SkipReason, skip: bool)

datatype ContinueDecision = ContinueDecision(action: Action, stage: Stage, reason: SkipReason, skip: bool)

function resumeEligibility(candidate: Candidate, evidence: Evidence, assessment: Assessment): SkipReason
{
  if candidate.isAddendum then
    SkipReason.AddendumBranch
  else
    if evidence.hasCollectionErrors then
      SkipReason.EvidenceCollectionError
    else
      if !(evidence.isClean) then
        SkipReason.DirtyWorktree
      else
        if !(evidence.hasCommits) then
          SkipReason.NoCommittedWork
        else
          if !(assessment.taskScoped) then
            SkipReason.NotTaskScoped
          else
            if assessment.hasMissingEvidence then
              SkipReason.MissingValidationEvidence
            else
              if !(candidate.hasExecplan) then
                SkipReason.MissingExecplan
              else
                SkipReason.NoReason
}

