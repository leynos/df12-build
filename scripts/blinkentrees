#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "inotify-simple>=1.3",
#   "rich>=13.0",
#   "textual>=0.89",
# ]
# ///
"""
blinkentrees - a Textual dasblinkenlights dashboard for sibling Git worktrees.

Linux-only: uses the native inotify API via inotify_simple.

Run from the parent directory containing worktrees:
    scripts/blinkentrees --pattern 'roadmap-*' .

Keys:
    r  force discovery rescan
    c  clear counters/feed
    q  quit
"""

from __future__ import annotations

import argparse
import errno
import fnmatch
import os
import queue
import sys
import time
from collections import Counter, deque
from dataclasses import dataclass, field
from pathlib import Path
from threading import Event
from typing import Callable, Deque, Iterable, Optional

try:
    from inotify_simple import INotify, flags
except ImportError as exc:  # pragma: no cover - friendly runtime failure
    raise SystemExit(
        "Missing dependency: inotify-simple\n"
        "Run this script with: uv run --script scripts/blinkentrees"
    ) from exc

try:
    from rich.panel import Panel
    from rich.table import Table
    from rich.text import Text
    from textual import work
    from textual.app import App, ComposeResult
    from textual.widgets import Footer, Header, Static
    from textual.worker import get_current_worker
except ImportError as exc:  # pragma: no cover - friendly runtime failure
    raise SystemExit(
        "Missing dependency: textual\n"
        "Run this script with: uv run --script scripts/blinkentrees"
    ) from exc


DEFAULT_EXCLUDES = {
    ".git",
    ".cache",
    ".idea",
    ".mypy_cache",
    ".nox",
    ".pytest_cache",
    ".ruff_cache",
    ".tox",
    ".venv",
    ".vscode",
    "__pycache__",
    "build",
    "coverage",
    "dist",
    "htmlcov",
    "node_modules",
    "target",
    "venv",
}

EVENT_STYLE = {
    "write": "bold green",
    "modify": "yellow",
    "create": "cyan",
    "delete": "bold red",
    "move_to": "magenta",
    "move_from": "bright_magenta",
    "attrib": "blue",
    "open": "dim white",
    "access": "dim white",
    "close_nowrite": "dim white",
    "ignored": "dim",
    "overflow": "bold white on red",
    "other": "white",
}

EVENT_LABEL = {
    "write": "WRITE",
    "modify": "MOD",
    "create": "NEW",
    "delete": "DEL",
    "move_to": "MOVE→",
    "move_from": "MOVE←",
    "attrib": "ATTR",
    "open": "OPEN",
    "access": "READ",
    "close_nowrite": "CLOSE",
    "ignored": "IGN",
    "overflow": "OVERFLOW",
    "other": "OTHER",
}

